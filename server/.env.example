PORT=3000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=macbearnet_homepage

# 관리자 로그인 (username / password)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# JWT 비밀키 (프로덕션에서는 반드시 변경)
JWT_SECRET=macbearnet-jwt-secret-change-in-production

# 프로덕션: CORS 허용 도메인 (쉼표 구분, 예: https://yourdomain.com,https://www.yourdomain.com)
# CORS_ORIGIN=

# 프로덕션: NODE_ENV=production
# NODE_ENV=production
