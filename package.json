{
  "name": "macbearnet-homepage",
  "version": "1.0.0",
  "description": "Vue.js + Node.js + MariaDB 홈페이지",
  "scripts": {
    "postinstall": "cd server && npm install && cd ../client && npm install",
    "install:all": "cd server && npm install && cd ../client && npm install",
    "dev": "concurrently -k \"npm run server\" \"npm run client\"",
    "dev:front": "cd client && npm run dev",
    "dev:front:prod": "cd client && npm run dev:prod",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "build:local": "cd client && npm run build:local"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
